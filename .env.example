###############################################################################
# arxiv-mail-reader — environment configuration
#
# Copy this file to `.env` (in the PROJECT ROOT, next to package.json) and
# fill in the values you need:
#
#     cp .env.example .env
#
# Everything here is read from the project root:
#   • Vite exposes only VITE_*-prefixed vars to the browser bundle.
#   • The Express server + the score-papers CLI read the rest via dotenv.
#   • Non-VITE_ secrets (API keys, DATABASE_URL) NEVER reach the client.
#
# All values are OPTIONAL — the app degrades gracefully:
#   • no DATABASE_URL  → IndexedDB-only mode (Books/Writer/Magazine disabled)
#   • no Google client → use IMAP login (iCloud / Outlook / Yahoo / Gmail)
#   • no AI provider   → tracker scoring falls back to keywords; no editorials
###############################################################################


# ─────────────────────────────────────────────────────────────────────────
# FRONTEND (Vite) — must be VITE_-prefixed to reach the browser
# ─────────────────────────────────────────────────────────────────────────

# Google OAuth client ID for "Sign in with Google" (Gmail digest fetching).
# Create one at https://console.cloud.google.com/apis/credentials
# Leave blank to hide the Google button and use IMAP login instead.
VITE_GOOGLE_CLIENT_ID=

# Base path the SPA is served under. Keep "/" (the default) unless you serve
# the app from a subdirectory.
# VITE_BASE_PATH=/


# ─────────────────────────────────────────────────────────────────────────
# SERVER (Express) — server/index.mjs
# ─────────────────────────────────────────────────────────────────────────

# Port the API server listens on (the Vite dev proxy forwards /api here).
PORT=3001

# Set to "production" only when serving the built dist/ from the server.
# Leave unset for local development.
# NODE_ENV=production

# Postgres connection. When set, the server connects on boot and enables
# the /api/db/* routes that power Books, Writer, Collections, Cross-refs,
# Magazine, and server-storage mode. Matches the docker-compose service
# (port 5433 avoids colliding with a local 5432).
#   Start it with:  npm run db:up
DATABASE_URL=postgres://arxiv:arxiv@localhost:5433/arxiv_reader

# Where uploaded book files are written on disk. Defaults to ./uploads.
# UPLOAD_ROOT=/absolute/path/to/uploads

# Set to 1 to stop the weekly Magazine auto-generation worker. Leave unset
# to let it run (it only acts on users who opted in via the Magazine UI).
# DISABLE_MAGAZINE_SCHEDULER=1

# Optional Semantic Scholar API key — raises rate limits ~10x for the
# Discover search + citation-graph features. Get one (free) at
# https://www.semanticscholar.org/product/api#api-key-form
SEMANTIC_SCHOLAR_API_KEY=

# Polite-pool email for OpenAlex (the Discover fallback when S2 throttles).
# OpenAlex gives faster, more reliable service to requests that identify
# themselves. Use any email you control.
OPENALEX_MAILTO=you@example.com


# ─────────────────────────────────────────────────────────────────────────
# score-papers CLI — scripts/score-papers.mjs only
#
# These configure the OFFLINE batch scorer (npm run score-papers).
# The running app's AI provider is configured separately in Settings →
# AI provider (stored in the browser); these vars are NOT used by the
# server, only by the CLI.
# ─────────────────────────────────────────────────────────────────────────

# claude | openai | groq | ollama | custom
AI_PROVIDER=ollama

# Base URL for the provider. Defaults are filled in per-provider, but you
# can override (e.g. a remote Ollama host).
AI_BASE_URL=http://localhost:11434/v1

# Model to score with. For high-volume batch scoring prefer a cheap/local
# model. Examples: llama3.2:latest, qwen3.5:latest (Ollama);
# gpt-4o-mini (OpenAI); llama-3.3-70b-versatile (Groq).
AI_MODEL=llama3.2:latest

# Required for every provider EXCEPT ollama.
AI_API_KEY=
