# Copy to server/.env and tweak as needed.
#
# The DATABASE_URL is OPTIONAL. When set, the Express server will:
#  - connect on startup
#  - expose CRUD endpoints under /api/db/*
#  - the client opts-in via Settings ("Use server storage")
#
# Leave it blank/unset to keep the current IndexedDB-only behaviour.

# DATABASE_URL=postgres://arxiv:arxiv@localhost:5433/arxiv_reader

# Optional: Semantic Scholar API key for the server's own usage
# SEMANTIC_SCHOLAR_API_KEY=

# Optional: polite-pool email for OpenAlex
# OPENALEX_MAILTO=you@example.com
